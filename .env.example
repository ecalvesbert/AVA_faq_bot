# Optional local overrides (copy to .env — never commit .env)
# GENESYS_PROFILE=DEFAULT
# GENESYS_ENVIRONMENT=mypurecloud.com
# GENESYS_CLIENT_ID=
# GENESYS_CLIENT_SECRET=

# Optional — Firecrawl demo works keyless without this
# Get a key at https://www.firecrawl.dev/app/api-keys
# FIRECRAWL_API_KEY=fc-...

# Web app (./run_web.sh) — see .env.railway.example for full Railway variable list
# DATA_DIR=artifacts
# AVA_AGENT_ID=your-ava-agent-uuid
# AVA_VERSION=6.0
# PIPELINE_API_KEY=
# CHAT_API_KEY=
