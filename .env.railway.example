# Railway deployment — copy to service variables (never commit secrets)

# Genesys OAuth (required for chat + pipeline sync)
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
GENESYS_ENVIRONMENT=mypurecloud.com

# AVA chat — your Agentic Virtual Agent in AI Studio
AVA_AGENT_ID=
AVA_VERSION=6.0
AVA_STUDIO_MODE=1
CHAT_TITLE=FAQ Assistant
CHAT_SUBTITLE=Ask questions about our products and services.

# Firecrawl (recommended on Railway — keyless tier is rate-limited)
FIRECRAWL_API_KEY=

# Persistent content store (mount Railway volume at this path)
DATA_DIR=/data

# Protect Admin tab, pipeline APIs, and chat API
PIPELINE_API_KEY=
CHAT_API_KEY=
REQUIRE_PIPELINE_KEY=1
REQUIRE_CHAT_KEY=1

# Optional: reuse existing Knowledge Fabric source
# KNOWLEDGE_SOURCE_ID=

PORT=8080
